# Copy this file to `.env` and adjust the values for your local setup.
# `loadEnvSync()` always loads `.env` first, then layers
# `.env.${NODE_ENV}` on top (e.g. `.env.production`, `.env.test`).
# Local-only overrides go in `.env.local` (gitignored).

# Application identity
APP_NAME=expressots-app

# HTTP server
PORT=3000

# Runtime
NODE_ENV=development

# Logger
# Levels: TRACE | DEBUG | INFO | WARN | ERROR | FATAL
LOG_LEVEL=INFO
