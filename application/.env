# Local environment overrides — copy from .env.example and adjust.
# Loaded first by `loadEnvSync()`; environment-specific files
# (`.env.production`, `.env.test`) layer on top when `NODE_ENV` matches.

# Application identity
APP_NAME=expressots-app

# HTTP server
PORT=3000

# Runtime
NODE_ENV=development

# Logger
# Levels: ALL | DEBUG | INFO | WARN | ERROR | FATAL | SILENT
LOG_LEVEL=INFO
