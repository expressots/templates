        "@expressots/cli": "file:../expressots-cli/expressots-cli-4.0.0-beta.1.tgz",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "25.0.3",
        "@typescript-eslint/eslint-plugin": "8.51.0",
        "@typescript-eslint/parser": "8.51.0",
        "eslint": "9.39.2",
        "jest": "30.0.0",
        "nodemon": "3.1.11",
        "prettier": "3.7.4",
        "ts-jest": "29.4.6",
        "tsconfig-paths": "4.2.0",
        "tsx": "4.21.0",
