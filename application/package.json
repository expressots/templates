        "express": "5.2.1"
    },
    "devDependencies": {
        "@eslint/js": "9.39.2",
        "@expressots/cli": "4.0.0-preview.3.4",
        "@expressots/studio": "4.0.0-preview.3.4",
        "@expressots/studio-agent": "4.0.0-preview.3.4",
        "@types/express": "5.0.6",
        "@types/jest": "30.0.0",
        "@types/node": "25.0.3",
        "@typescript-eslint/eslint-plugin": "8.61.0",
        "@typescript-eslint/parser": "8.61.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "eslint": "9.39.2",
        "jest": "30.0.0",
        "prettier": "3.7.4",
        "ts-jest": "29.4.6",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.61.0"
    }
