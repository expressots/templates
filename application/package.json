{
    "name": "expressots-app",
    "version": "1.0.0",
    "description": "ExpressoTS Application",
    "author": "",
    "license": "MIT",
    "main": "dist/src/main.js",
    "scripts": {
        "dev": "expressots dev",
        "build": "expressots build",
        "prod": "expressots prod",
